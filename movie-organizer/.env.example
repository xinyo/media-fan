# Movie Organizer — Environment Configuration
#
# Copy this file to .env and fill in your values.
# The scripts will fall back to sensible defaults if these are not set.

# Input: where unorganized movies live (folders or loose files)
MOVIE_INPUT=/mnt/lib3/waiting/movie--

# Output: root directory for organized movies (subdirectories: en/, cn/, hk/, asia/, other/)
MOVIE_OUTPUT=/mnt/lib3/media/movie

# TMDB API key (required) — get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: OpenSubtitles credentials for automatic subtitle download
# Sign up at https://www.opensubtitles.com
# OPENSUBTITLES_API_KEY=
# OPENSUBTITLES_USERNAME=
# OPENSUBTITLES_PASSWORD=

# Optional: SubDL API key (fallback subtitle provider)
# SUBDL_API_KEY=
